      <table>
        <view>
          <datasources>
            <datasource caption='airpoll_dataset (air_pollution_dataset)' name='federated.17fuas5135xx0o1bx0mi508hingu' />
          </datasources>
          <datasource-dependencies datasource='federated.17fuas5135xx0o1bx0mi508hingu'>
            <column caption='City' datatype='string' name='[city]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column-instance column='[city]' derivation='None' name='[none:city:nk]' pivot='key' type='nominal' />
            <column caption='Pollutant Avg' datatype='integer' name='[pollutant_avg]' role='measure' type='quantitative' />
            <column-instance column='[pollutant_avg]' derivation='Sum' name='[sum:pollutant_avg:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.17fuas5135xx0o1bx0mi508hingu].[none:city:nk]'>
            <groupfilter count='1' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([pollutant_avg])' function='order' user:ui-marker='order'>
